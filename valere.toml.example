[model]
embedding = { provider = "ollama", model = "nomic-embed-text", base_url = "http://localhost:11434" }
experiment = { provider = "ollama", model = "llama3.2:1b", base_url = "http://localhost:11434" }
hypothesis = { provider = "xai", model = "grok-4-1-fast-reasoning" }

[experiment]
max_runs = 10
max_seconds = 40.0
prompt_sys = "prompt_variation.txt"
prompt_user = ""

[paths]
sys_hypothesis = "sys_hypothesis.txt"
user_hypothesis = "user_hypothesis_template.txt"
results_log = "results_log.tsv"
